# ike-komet-ws .gitignore
# ═══════════════════════
#
# Ignore everything, whitelist only workspace-owned files.
# Subproject repos are independent git repos cloned by ws:init.

# ── Ignore everything by default ─────────────────────────────────
*

# ── Whitelist workspace-level files ──────────────────────────────
!.gitignore
!pom.xml
!workspace.yaml
!README.adoc
!GOALS.md
!WS-REFERENCE.md
!mvnw
!mvnw.cmd
!versions-upgrade-rules.yaml

# ── Whitelist scaffold lockfile ──────────────────────────────────
!.ike/
!.ike/scaffold.lock

# ── Whitelist workspace-owned directories ────────────────────────
!.mvn/
!.mvn/**
!checkpoints/
!checkpoints/**
!.run/
!.run/**

# ── IntelliJ project config (curated slice) ──────────────────────
# Small, stable project-wide settings shared across collaborators.
# compiler.xml and vcs.xml are excluded — they regenerate per
# Maven reload or per workspace membership.
!.idea/
!.idea/.gitignore
!.idea/misc.xml
!.idea/kotlinc.xml
!.idea/encodings.xml
!.idea/jarRepositories.xml

# ws:* goal reports
ws꞉*.md
!.gitattributes
# BEGIN ike-managed
# Scaffold-tracked files (whitelisted out of the catch-all ignore)
!versions-upgrade-rules.yaml
!.ike/
!.ike/scaffold.lock
# END ike-managed

# ike:* goal reports
ike꞉*.md
